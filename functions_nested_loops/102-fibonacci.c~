#include <stdio.h>

/**
 * main - Prints the first 50 Fibonacci numbers starting with 1 and 2,
 *        separated by a comma and a space, followed by a new line.
 *
 * Return: Always 0.
 */
int main(void)
{
unsigned long long a = 1, b = 2, next;
int i;

for (i = 1; i <= 50; i++)
{
if (i == 50)
printf("%llu\n", a);
else
printf("%llu, ", a);

next = a + b;
a = b;
b = next;
}

return (0);
}
